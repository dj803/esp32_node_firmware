# Repo-root ignore patterns. The firmware subdir
# (esp32_node_firmware/.gitignore) covers PlatformIO build artefacts.

# PlatformIO + cross-builds (in case someone runs pio at the repo root)
.pio/

# Build output binaries — release artefacts live on gh-pages, not in git
*.bin
*.hex
*.elf

# OS metadata
.DS_Store
Thumbs.db

# Local logs and lock files (Claude scheduled-tasks lock, etc.)
Logs/
.claude/scheduled_tasks.lock

# Per-rollout logs from tools/dev/ota-rollout.sh — written to wherever
# the script was invoked. One file per rollout, ~2-5 KB each. Useful
# for forensics after the fact but not source-controlled.
ota-rollout-*.jsonl

# Python build / cache
__pycache__/
*.pyc
