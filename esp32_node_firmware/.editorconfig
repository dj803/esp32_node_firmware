# EditorConfig — keeps whitespace/EOL consistent across editors.
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

# C/C++/Arduino sources — 4-space indent (matches existing source style)
[*.{c,cpp,cc,cxx,h,hpp,ino,S}]
indent_size = 4

# Python tooling (extra_scripts, CI helpers)
[*.py]
indent_size = 4

# YAML/JSON/TOML — 2-space indent
[*.{yml,yaml,json,toml}]
indent_size = 2

# Markdown — preserve trailing whitespace (hard-break syntax)
[*.md]
trim_trailing_whitespace = false
indent_size = 2

# PlatformIO config files use INI syntax
[platformio.ini]
indent_size = 4

# Makefiles require real tabs
[Makefile]
indent_style = tab
