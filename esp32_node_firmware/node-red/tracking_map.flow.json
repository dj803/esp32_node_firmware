  {
    "id": "map_anchor_fn",
    "type": "function",
    "z": "map_tab",
    "name": "Anchor Registry",
    "func": "try {\n    var p = msg.payload || {};\n    var uuid = (msg.topic || '').split('/')[6] || p.device_id || '';\n    if (!uuid) return null;\n    var anchors = flow.get('map_anchors') || {};\n    if (p.online === false || p.event === 'offline') {\n        // LWT — mark offline but keep position\n        if (anchors[uuid]) anchors[uuid].online = false;\n        flow.set('map_anchors', anchors);\n        return { payload: { anchors: Object.values(anchors) } };\n    }\n    var isAnchor = p.anchor && p.anchor.role === 'anchor';\n    var name = (p.node_name || '').trim() || uuid.slice(0, 8) + '...';\n    anchors[uuid] = {\n        uuid:    uuid,\n        mac:     p.mac || '',\n        name:    name,\n        online:  true,\n        is_anchor: isAnchor,\n        x_m:     isAnchor ? (p.anchor.x_m || 0) : null,\n        y_m:     isAnchor ? (p.anchor.y_m || 0) : null,\n        z_m:     isAnchor ? (p.anchor.z_m || 0) : null,\n        wifi_ch: p.wifi_channel || 0,\n        last_seen: Date.now()\n    };\n    flow.set('map_anchors', anchors);\n    // Channel mismatch check\n    var anchorList = Object.values(anchors).filter(function(a) { return a.is_anchor && a.online; });\n    var channels = [...new Set(anchorList.map(function(a) { return a.wifi_ch; }).filter(Boolean))];\n    var channelWarning = channels.length > 1 ? 'Anchors on channels ' + channels.join(', ') + ' — ESP-NOW will not work across channels' : '';\n    flow.set('map_channel_warning', channelWarning);\n    return { payload: { anchors: Object.values(anchors), channelWarning: channelWarning } };\n} catch(e) {\n    node.error('Anchor Registry: ' + e.message, msg);\n    return null;\n}",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 360,
    "y": 80,
    "wires": [["map_canvas_tpl", "map_anchor_tpl"]]
  },
  {
    "id": "map_espnow_in",
    "type": "mqtt in",
    "z": "map_tab",
    "name": "espnow (all nodes)",
    "topic": "Enigma/JHBDev/+/+/+/ESP32NodeBox/+/espnow",
    "qos": "1",
    "datatype": "json",
    "broker": "mqtt_broker",
    "nl": false,
    "rap": false,
    "rh": 0,
    "inputs": 0,
    "x": 120,
    "y": 200,
    "wires": [["map_range_fn"]]
  },
  {
    "id": "map_range_fn",
    "type": "function",
    "z": "map_tab",
    "name": "Collect Range Obs",
    "func": "try {\n    var p = msg.payload || {};\n    var observerUuid = (msg.topic || '').split('/')[6] || '';\n    var anchors = flow.get('map_anchors') || {};\n    var ranges = flow.get('map_ranges') || {}; // {mobileUuid: {anchorUuid: d_m}}\n    var peers = Array.isArray(p.peers) ? p.peers : [];\n    // Find which anchors are in this observer's peer list\n    var anchorList = Object.values(anchors).filter(function(a) { return a.is_anchor && a.online; });\n    peers.forEach(function(peer) {\n        if (!peer.mac) return;\n        var anchor = anchorList.find(function(a) { return a.mac === peer.mac; });\n        if (!anchor) return;\n        if (!ranges[observerUuid]) ranges[observerUuid] = {};\n        ranges[observerUuid][anchor.uuid] = parseFloat(peer.dist_m) || 0;\n    });\n    flow.set('map_ranges', ranges);\n    // Attempt to solve position for this mobile observer\n    var myAnchors = anchorList.filter(function(a) {\n        return ranges[observerUuid] && ranges[observerUuid][a.uuid] !== undefined;\n    });\n    if (myAnchors.length < 1) return null;\n    var observerName = (p.node_name || '').trim() || observerUuid.slice(0, 8) + '...';\n    var pos = solvePosition(myAnchors, ranges[observerUuid]);\n    msg.payload = {\n        uuid:         observerUuid,\n        name:         observerName,\n        x_m:          pos.x,\n        y_m:          pos.y,\n        residual_m:   pos.residual,\n        anchors_used: myAnchors.map(function(a) { return a.name; }),\n        method:       pos.method\n    };\n    return msg;\n} catch(e) {\n    node.error('Collect Range Obs: ' + e.message, msg);\n    return null;\n}\n\nfunction solvePosition(anchors, ranges) {\n    if (anchors.length === 1) {\n        // Only one anchor: place mobile at distance d on a ring (angle unknown)\n        var d = ranges[anchors[0].uuid] || 0;\n        return { x: anchors[0].x_m + d, y: anchors[0].y_m, residual: 0, method: 'polar-1anc' };\n    }\n    if (anchors.length === 2) {\n        // Two anchors: two circles, two intersection points — pick the one with positive Y\n        var a1 = anchors[0], a2 = anchors[1];\n        var d1 = ranges[a1.uuid] || 0, d2 = ranges[a2.uuid] || 0;\n        var dx = a2.x_m - a1.x_m, dy = a2.y_m - a1.y_m;\n        var D = Math.sqrt(dx*dx + dy*dy);\n        if (D < 0.01) return { x: a1.x_m, y: a1.y_m, residual: 999, method: 'degenerate' };\n        var a = (d1*d1 - d2*d2 + D*D) / (2*D);\n        var h2 = d1*d1 - a*a;\n        if (h2 < 0) h2 = 0;\n        var h = Math.sqrt(h2);\n        var mx = a1.x_m + a*dx/D, my = a1.y_m + a*dy/D;\n        // Pick the intersection point (arbitrary: +h)\n        return { x: mx + h*dy/D, y: my - h*dx/D, residual: 0, method: '2-circle' };\n    }\n    // N >= 3: Gauss-Newton least-squares (2D)\n    // Initial estimate: weighted centroid (weights = 1/d)\n    var sx = 0, sy = 0, sw = 0;\n    anchors.forEach(function(a) {\n        var d = ranges[a.uuid] || 1;\n        var w = 1 / Math.max(d, 0.1);\n        sx += a.x_m * w; sy += a.y_m * w; sw += w;\n    });\n    var x = sx/sw, y = sy/sw;\n    for (var iter = 0; iter < 20; iter++) {\n        var J1 = 0, J2 = 0, J3 = 0, J4 = 0, r1 = 0, r2 = 0;\n        var maxStep = 0;\n        anchors.forEach(function(a) {\n            var dx2 = x - a.x_m, dy2 = y - a.y_m;\n            var pred = Math.sqrt(dx2*dx2 + dy2*dy2);\n            if (pred < 1e-6) pred = 1e-6;\n            var res = pred - (ranges[a.uuid] || 0);\n            var jx = dx2/pred, jy = dy2/pred;\n            J1 += jx*jx; J2 += jx*jy; J3 += jy*jy;\n            r1 += jx*res; r2 += jy*res;\n        });\n        // Solve 2x2 system [J1 J2; J2 J3][dx;dy] = [r1;r2]\n        var det = J1*J3 - J2*J2;\n        if (Math.abs(det) < 1e-10) break;\n        var dx3 = (J3*r1 - J2*r2) / det;\n        var dy3 = (J1*r2 - J2*r1) / det;\n        x -= dx3; y -= dy3;\n        maxStep = Math.sqrt(dx3*dx3 + dy3*dy3);\n        if (maxStep < 0.001) break;\n    }\n    // Compute residual (RMS)\n    var sumSq = 0;\n    anchors.forEach(function(a) {\n        var dx2 = x - a.x_m, dy2 = y - a.y_m;\n        var pred = Math.sqrt(dx2*dx2 + dy2*dy2);\n        var res = pred - (ranges[a.uuid] || 0);\n        sumSq += res*res;\n    });\n    var rms = Math.sqrt(sumSq / anchors.length);\n    return { x: x, y: y, residual: rms, method: 'gauss-newton-' + anchors.length + 'anc' };\n}",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 360,
    "y": 200,
    "wires": [["map_canvas_tpl", "map_mqtt_out"]]
  },
  {
    "id": "map_mqtt_out",
