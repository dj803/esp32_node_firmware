{
  "C_Cpp.intelliSenseEngine": "default",
  "C_Cpp.default.configurationProvider": "platformio.platformio-ide",
  "files.associations": {
    "*.ino": "cpp",
    "*.h": "c"
  },
  "files.exclude": {
    ".pio/**": true,
    ".pioenvs/**": true,
    ".piolibdeps/**": true
  },
  "search.exclude": {
    ".pio/**": true,
    "**/node_modules/**": true
  },
  "files.watcherExclude": {
    "**/.pio/**": true
  },
  "editor.formatOnSave": false,
  "[cpp]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  }
}
